# Frontend repo — connection settings only.
# Backend secrets (OpenAI, DB, SMTP, JWT) belong in D:\AI-Interview-Model-B-V2\.env

# Path to backend repo (optional; frontend\start.bat defaults to sibling AI-Interview-Model-B-V2).
# BACKEND_ROOT=D:\AI-Interview-Model-B-V2

# Admin dashboard Vite dev server — API proxy target (npm run dev in frontend/admin-dashboard).
# Monolith:  http://127.0.0.1:2020
# Gateway:   http://localhost:8080
# VITE_BACKEND_URL=http://127.0.0.1:2020
